---
---

<section class="relative w-full overflow-x-clip py-20 bg-bg">
    <div class="w-full max-w-7xl mx-auto px-6 sm:px-10 overflow-hidden mb-12 select-none pointer-events-none">
        <div class="w-full flex justify-center -rotate-[3deg]">
            <img src="/people.png" alt="" class="w-full h-auto max-h-[260px] lg:h-[300px] object-contain" />
        </div>
    </div>

    <div class="w-full px-6 sm:px-10 mx-auto max-w-4xl text-center relative z-10 my-8">
        <h2 class="text-[32px] sm:text-[45px] lg:text-[52px] font-extrabold tracking-tight mb-8">
            <span class="text-black">Co mówią</span> <span class="bg-gradient text-transparent bg-clip-text">użytkownicy?</span>
        </h2>

        <div class="flex justify-center items-center gap-1.5 mb-6 text-amber-400">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>

        <div class="relative flex items-center justify-between max-w-3xl mx-auto mb-8 px-4 sm:px-12">
            <button type="button" aria-label="Previous" class="absolute left-0 sm:-left-4 w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-gray-50 transition-colors cursor-pointer z-20">
                <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
            </button>

            <div class="mx-auto text-center px-4">
                <p class="text-[17px] sm:text-[22px] text-gray-800 font-medium leading-relaxed mb-4">
                    &quot;Super pomysł, tego właśnie brakowało – nikt nie lubi szukać mieszkania przez olx albo przez Facebooka.&quot;
                </p>
                <h3 class="text-[16px] sm:text-[18px] font-bold text-black">
                    kisiel123
                </h3>
            </div>

            <button type="button" aria-label="Next" class="absolute right-0 sm:-right-4 w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-gray-50 transition-colors cursor-pointer z-20">
                <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>

        <div class="flex justify-center items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-gray-300 cursor-pointer"></span>
            <span class="w-6 h-2 rounded-full bg-purple cursor-pointer"></span>
            <span class="w-2 h-2 rounded-full bg-gray-300 cursor-pointer"></span>
        </div>
    </div>

    <div class="w-full max-w-7xl mx-auto px-6 sm:px-10 overflow-hidden mt-12 select-none pointer-events-none">
        <div class="w-full flex justify-center rotate-[3deg]">
            <img src="/people2.png" alt="" class="w-full h-auto max-h-[260px] lg:h-[300px] object-contain" />
        </div>
    </div>
</section>