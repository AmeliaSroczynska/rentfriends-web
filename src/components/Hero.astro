---
---

<section class="relative w-full overflow-x-clip">
    <div class="w-full px-6 sm:px-10 mx-auto max-w-7xl pt-[70px] pb-20 lg:pb-32 relative flex flex-col lg:flex-row items-start">
        <img src="/purple-gradient.png" aria-hidden="true" class="absolute -top-[50px] left-[-80px] lg:-top-[70px] lg:-left-[300px] w-[550px] lg:w-[764px] h-auto lg:h-[556px] -z-10 max-w-none pointer-events-none opacity-90 lg:opacity-100" />

        <div class="w-full lg:w-[60%] flex flex-col items-start text-left z-10 relative">
            <div class="flex items-center gap-2 mb-6">
                <div class="w-2 h-2 rounded-full bg-purple"></div>
                <span class="text-purple font-medium text-[14px]">Wynajem bez niespodzianek</span>
            </div>

            <h1 class="text-[42px] sm:text-[55px] lg:text-[69px] font-extrabold leading-[1.05] tracking-tight mb-4">
                <span class="text-black">
                    Znajdź<br />
                    współlokatora,<br />
                    z&nbsp;którym
                </span><br />
                <span class="bg-gradient text-transparent bg-clip-text pb-2 box-decoration-clone">
                    mieszkanie&nbsp;będzie<br />
                    przyjemnością!
                </span>
            </h1>

            <p class="text-[17.5px] text-gray max-w-[550px] mb-10 leading-relaxed font-normal">
                Inteligentne dopasowanie, zarządzanie mieszkaniem i spokój ducha – wszystko w jednej aplikacji.
            </p>

            <div class="flex flex-wrap items-center gap-4 mb-12">
                <button type="button" class="flex items-center gap-3 bg-black text-white px-5 py-2.5 rounded-[10px] hover:opacity-90 transition-opacity cursor-default">
                    <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M4 2.5v19l14.4-9.5L4 2.5zm1.5 2.6l10.5 6.9-10.5 6.9V5.1z" />
                    </svg>
                    <div class="text-left flex flex-col justify-center">
                        <span class="block text-[10px] font-medium tracking-wide uppercase">Pobierz z</span>
                        <span class="block text-[17px] font-semibold -mt-1">Google Play</span>
                    </div>
                </button>

                <button type="button" class="flex items-center gap-3 bg-black text-white px-5 py-2.5 rounded-[10px] hover:opacity-90 transition-opacity cursor-default">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16.36 14.4c-.02-2.3 1.96-3.4 2.05-3.46-1.07-1.52-2.73-1.74-3.32-1.77-1.42-.14-2.78.8-3.5.8-.73 0-1.84-.78-3.02-.76-1.52.02-2.92.85-3.7 2.15-1.58 2.67-.4 6.64 1.14 8.78.75 1.05 1.63 2.22 2.8 2.17 1.12-.05 1.55-.7 2.92-.7 1.35 0 1.76.7 2.93.67 1.2-.02 1.95-1.07 2.68-2.12.85-1.18 1.2-2.33 1.22-2.4-.03-.02-2.17-.8-2.2-3.36zm-2.02-4.22c.6-.72.98-1.7.88-2.68-.83.04-1.9.54-2.52 1.26-.54.6-.98 1.62-.86 2.58.94.07 1.9-.45 2.5-1.16z" />
                    </svg>
                    <div class="text-left flex flex-col justify-center">
                        <span class="block text-[10px] font-medium tracking-wide">Pobierz w</span>
                        <span class="block text-[17px] font-semibold -mt-1">App Store</span>
                    </div>
                </button>
            </div>

            <div class="flex flex-wrap items-center gap-4 sm:gap-8 text-[14px] font-normal text-gray">
                <span><strong class="font-bold text-black text-[20px] mr-2">3000+</strong>użytkowników</span>
                <span class="hidden sm:block w-[1px] h-4 bg-gray/30"></span>
                <span><strong class="font-bold text-black text-[20px] mr-2">4.6★</strong>ocena</span>
                <span class="hidden sm:block w-[1px] h-4 bg-gray/30"></span>
                <span><strong class="font-bold text-black text-[20px] mr-2">Bezpłatna</strong>aplikacja</span>
            </div>
        </div>

        <div class="hidden lg:block absolute top-[-47px] right-[-120px] xl:right-[-500px] z-20 pointer-events-none">
            <img src="/hero-phone.png" alt="Aplikacja RentFriends w dłoni" class="h-[870px] w-auto max-w-none object-contain" />
        </div>

        <div class="w-full flex justify-center mt-12 lg:hidden relative z-10">
            <img src="/hero-phone.png" alt="Aplikacja RentFriends w dłoni" class="h-[440px] w-auto max-w-none object-contain" />
        </div>
    </div>
</section>