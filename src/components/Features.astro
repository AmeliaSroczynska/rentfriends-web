---
---

<section class="w-full bg-[#F4F2EE] font-sans pt-16 pb-32 overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-6 sm:px-10 relative">

        <div class="relative w-full">

            <div class="hidden lg:block absolute top-0 bottom-0 pointer-events-none z-0 w-full">

                <svg class="absolute top-[10px]" style="left: calc(-50vw + 50% + 130px);" xmlns="http://www.w3.org/2000/svg" width="67" height="67" viewBox="0 0 67 67" fill="none">
                    <path d="M34 56V67H1.39876e-06L1.04907e-06 56H34Z" fill="#0F0F0F"/>
                    <path d="M0 32H10.0561V64H1.39876e-06L0 32Z" fill="#0F0F0F"/>
                    <path d="M33.4941 0C51.9957 0 66.9941 14.9985 66.9941 33.5C66.9941 51.8346 52.2651 66.7258 33.9941 66.9932L34 56C47.5 56 57 47 57 33.5C57 20 47 11 33.5 11C19.5 11 10.2655 21.9092 10 33H1.39876e-06C0.267335 14.729 15.1596 0 33.4941 0Z" fill="#0F0F0F"/>
                </svg>

                <div class="absolute top-[77px] bottom-[261px] w-[10px] bg-[#0F0F0F]" style="left: calc(-50vw + 50% + 130px);"></div>

                <div class="absolute bottom-[221px] w-[40px] h-[40px] border-l-[10px] border-b-[10px] border-[#0F0F0F] rounded-bl-[40px]" style="left: calc(-50vw + 50% + 130px);"></div>

                <div class="absolute bottom-[221px] h-[10px] bg-[#0F0F0F]" style="left: calc(-50vw + 50% + 170px); right: calc(100% - 680px);"></div>

                <svg class="absolute bottom-[210px] left-[679px] w-[26px] h-[32px]" viewBox="0 0 26 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M26 16L0 32V0L26 16Z" fill="#0F0F0F"/>
                </svg>

            </div>

            <div class="relative z-10 w-full">

                <header class="text-left mb-12 -mt-4 relative pl-[20px]">
                    <h2 class="text-[#0F0F0F] text-[48px] font-[800] leading-normal tracking-[-1.44px]">
                        Jak działa RentFriends?
                    </h2>
                    <p class="text-[#595959] text-[24px] font-[500] mt-1">
                        Zobacz jakie to proste!
                    </p>
                </header>

                <div class="flex flex-col gap-12 lg:gap-16 w-full mt-[100px]">

                    <div class="grid grid-cols-1 lg:grid-cols-2 items-center w-full relative">
                        <div class="hidden lg:block absolute top-1/2 -translate-y-1/2 w-[42px] h-[42px] rounded-full border-[10px] border-[#0F0F0F] bg-[#F4F2EE] z-20" style="left: calc(-50vw + 50% + 114px);"></div>

                        <div class="w-full flex justify-center lg:justify-start lg:pl-[130px]">
                            <img src="/step-1.png" alt="Załóż konto" class="w-1/2 h-auto object-contain" />
                        </div>

                        <div class="w-full mt-6 lg:mt-0">
                            <h3 class="text-[#0F0F0F] text-[36px] font-[800] leading-[45px] tracking-[-1.44px] mb-4">
                                Załóż konto
                            </h3>
                            <p class="text-[#595959] text-[20px] font-[500] leading-snug lg:pr-10">
                                Szukasz pokoju czy masz wolne łóżko? Opisz swoje nawyki, rutynę i stwórz profil, który przyciągnie ludzi podobnych do Ciebie.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 items-center w-full relative">
                        <div class="hidden lg:block absolute top-1/2 -translate-y-1/2 w-[42px] h-[42px] rounded-full border-[10px] border-[#0F0F0F] bg-[#F4F2EE] z-20" style="left: calc(-50vw + 50% + 114px);"></div>

                        <div class="w-full flex justify-center lg:justify-start lg:pl-[130px]">
                            <img src="/step-2.png" alt="Swipe'uj profile" class="w-1/2 h-auto object-contain drop-shadow-xl" />
                        </div>

                        <div class="w-full mt-6 lg:mt-0">
                            <h3 class="text-[#0F0F0F] text-[36px] font-[800] leading-[45px] tracking-[-1.44px] mb-4">
                                Swipe'uj profile
                            </h3>
                            <p class="text-[#595959] text-[20px] font-[500] leading-snug lg:pr-10">
                                Szybka ocena na interaktywnych kartach. Przesuwaj w prawo oferty, które spełniają Twoje kryteria.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 items-center w-full relative">
                        <div class="hidden lg:block absolute top-1/2 -translate-y-1/2 w-[42px] h-[42px] rounded-full border-[10px] border-[#0F0F0F] bg-[#F4F2EE] z-20" style="left: calc(-50vw + 50% + 114px);"></div>

                        <div class="w-full flex justify-center lg:justify-start lg:pl-[130px]">
                            <img src="/step-3.png" alt="Znajdź idealnego matcha" class="w-1/2 h-auto object-contain drop-shadow-xl scale-130" />
                        </div>

                        <div class="w-full mt-6 lg:mt-0">
                            <h3 class="text-[#0F0F0F] text-[36px] font-[800] leading-[45px] tracking-[-1.44px] mb-4">
                                Znajdź idealnego matcha
                            </h3>
                            <p class="text-[#595959] text-[20px] font-[500] leading-snug lg:pr-10">
                                Nasz algorytm łączy osoby o podobnym stylu życia, gwarantując mniej konfliktów w przyszłości.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 items-center w-full relative">
                        <div class="hidden lg:block absolute top-1/2 -translate-y-1/2 w-[42px] h-[42px] rounded-full border-[10px] border-[#0F0F0F] bg-[#F4F2EE] z-20" style="left: calc(-50vw + 50% + 114px);"></div>

                        <div class="w-full flex justify-center lg:justify-start lg:pl-[130px]">
                            <img src="/step-4.png" alt="Czatuj" class="w-1/2 h-auto object-contain drop-shadow-xl" />
                        </div>

                        <div class="w-full mt-6 lg:mt-0">
                            <h3 class="text-[#0F0F0F] text-[36px] font-[800] leading-[45px] tracking-[-1.44px] mb-4">
                                Czatuj
                            </h3>
                            <p class="text-[#595959] text-[20px] font-[500] leading-snug lg:pr-10">
                                Zanim podpiszecie umowę, poznajcie się bliżej w naszym bezpiecznym, wbudowanym czacie.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 items-center w-full relative">
                        <div class="hidden lg:block absolute top-1/2 -translate-y-1/2 w-[42px] h-[42px] rounded-full border-[10px] border-[#0F0F0F] bg-[#F4F2EE] z-20" style="left: calc(-50vw + 50% + 114px);"></div>

                        <div class="w-full flex justify-center lg:justify-start lg:pl-[130px]">
                            <img src="/step-5.png" alt="Zamieszkaj razem" class="w-1/2 h-auto object-contain drop-shadow-xl" />
                        </div>

                        <div class="w-full mt-6 lg:mt-0">
                            <h3 class="text-[#0F0F0F] text-[36px] font-[800] leading-[45px] tracking-[-1.44px] mb-4">
                                Zamieszkaj razem:<br />
                                rozdziel dyżury i podziel wydatki
                            </h3>
                            <p class="text-[#595959] text-[20px] font-[500] leading-snug lg:pr-10">
                                Rachunki, grafik sprzątania i zakupy w jednej aplikacji. Przejrzysty podział obowiązków to gwarancja spokoju w mieszkaniu.
                            </p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="mt-12 lg:mt-[150px] pb-12 lg:pb-[20px] flex flex-col lg:flex-row items-center justify-between lg:pl-[120px] relative z-10">

                <div class="mb-12 lg:mb-0 text-center lg:text-left relative bg-[#F4F2EE] pr-4 top-[-120px]">
                    <h3 class="text-[#0F0F0F] text-[32px] sm:text-[40px] font-[800] tracking-tight">
                        Dołącz do naszej społeczności
                    </h3>
                </div>

                <div class="grid grid-cols-2 gap-4 lg:gap-6 bg-[#F4F2EE] lg:translate-x-[60px]">
                    <div class="w-[160px] h-[160px] sm:w-[186px] sm:h-[189px] bg-[#F4F2EE] rounded-[50px] rounded-br-none shadow-[0_0_33.5px_0_rgba(0,0,0,0.25)] flex p-[19px]">
                        <div class="flex flex-col items-end justify-start w-full h-full text-right">
                            <span class="text-[60px] sm:text-[85px] font-[700] leading-none bg-[linear-gradient(100deg,#234CE0_6.17%,#A247E3_50%,#E95BD2_93.83%)] bg-clip-text text-transparent inline-block">
                                3k
                            </span>
                            <span class="text-[#595959] text-[12px] sm:text-[14px] font-[500] leading-tight mt-2">
                                zadowolonych<br />użytkowników
                            </span>
                        </div>
                    </div>

                    <div class="w-[160px] h-[160px] sm:w-[186px] sm:h-[189px] bg-[#F4F2EE] rounded-[50px] rounded-bl-none shadow-[0_0_33.5px_0_rgba(0,0,0,0.25)] flex p-[19px]">
                        <div class="flex flex-col items-start justify-start w-full h-full text-left">
                            <span class="text-[60px] sm:text-[85px] font-[700] leading-none bg-[linear-gradient(100deg,#234CE0_6.17%,#A247E3_50%,#E95BD2_93.83%)] bg-clip-text text-transparent inline-block">
                                3
                            </span>
                            <span class="text-[#595959] text-[12px] sm:text-[14px] font-[500] leading-tight mt-2">
                                miesiące<br />funkcjonowania<br />aplikacji
                            </span>
                        </div>
                    </div>

                    <div class="w-[160px] h-[160px] sm:w-[186px] sm:h-[189px] bg-[#F4F2EE] rounded-[50px] rounded-tr-none shadow-[0_0_33.5px_0_rgba(0,0,0,0.25)] flex p-[19px]">
                        <div class="flex flex-col items-end justify-start w-full h-full text-right">
                            <span class="text-[60px] sm:text-[85px] font-[700] leading-none bg-[linear-gradient(100deg,#234CE0_6.17%,#A247E3_50%,#E95BD2_93.83%)] bg-clip-text text-transparent inline-block">
                                4.6
                            </span>
                            <span class="text-[#595959] text-[12px] sm:text-[14px] font-[500] leading-tight mt-2">
                                średnia ocen<br />na App Store
                            </span>
                        </div>
                    </div>

                    <div class="w-[160px] h-[160px] sm:w-[186px] sm:h-[189px] bg-[#F4F2EE] rounded-[50px] rounded-tl-none shadow-[0_0_33.5px_0_rgba(0,0,0,0.25)] flex p-[19px]">
                        <div class="flex flex-col items-start justify-start w-full h-full text-left">
                            <span class="text-[60px] sm:text-[85px] font-[700] leading-none bg-[linear-gradient(100deg,#234CE0_6.17%,#A247E3_50%,#E95BD2_93.83%)] bg-clip-text text-transparent inline-block">
                                0zł
                            </span>
                            <span class="text-[#595959] text-[12px] sm:text-[14px] font-[500] leading-tight mt-2">
                                opłat za<br />użytkowanie
                            </span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>