---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="RentFriends">
	<Navbar />

	<main class="flex flex-col items-center justify-center min-h-[calc(100vh-72px)] px-6 py-12 text-center">
		<h1 class="max-w-4xl text-5xl md:text-[64px] font-bold tracking-tight leading-tight mb-16">
            <span class="bg-gradient text-transparent bg-clip-text">
                Znajdź współlokatora, z<br class="hidden md:block" />
                którym mieszkanie będzie<br class="hidden md:block" />
                przyjemnością!
            </span>
		</h1>

		<div class="flex flex-wrap justify-center gap-6 mb-16">
			<div class="w-32 h-32 bg-purple rounded-[24px] flex items-center justify-center text-white font-semibold text-lg shadow-sm">
				Purple
			</div>
			<div class="w-32 h-32 bg-blue rounded-[24px] flex items-center justify-center text-white font-semibold text-lg shadow-sm">
				Blue
			</div>
			<div class="w-32 h-32 bg-pink rounded-[24px] flex items-center justify-center text-white font-semibold text-lg shadow-sm">
				Pink
			</div>
			<div class="w-32 h-32 bg-black rounded-[24px] flex items-center justify-center text-white font-semibold text-lg shadow-sm">
				Black
			</div>
		</div>

		<a href="#download" class="px-10 py-4 bg-gradient text-white font-bold rounded-full shadow-lg hover:opacity-90 hover:scale-[1.02] active:scale-95 transition-all duration-300 ease-out text-lg">
			Download App
		</a>
	</main>
</Layout>