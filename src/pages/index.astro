---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="flex flex-col items-center justify-center min-h-screen p-8 gap-12">

		<h1 class="text-5xl font-bold bg-gradient bg-clip-text text-transparent text-center max-w-2xl leading-tight">
			Znajdź współlokatora, z którym mieszkanie będzie przyjemnością!
		</h1>

		<div class="flex gap-6">
			<div class="w-24 h-24 bg-purple flex items-center justify-center text-white font-bold rounded-xl shadow-md">Purple</div>
			<div class="w-24 h-24 bg-blue flex items-center justify-center text-white font-bold rounded-xl shadow-md">Blue</div>
			<div class="w-24 h-24 bg-pink flex items-center justify-center text-white font-bold rounded-xl shadow-md">Pink</div>
			<div class="w-24 h-24 bg-black flex items-center justify-center text-white font-bold rounded-xl shadow-md">Black</div>
		</div>

		<button class="px-10 py-4 bg-gradient text-white font-bold rounded-full shadow-lg hover:opacity-90 transition-opacity">
			Download App
		</button>

	</main>
</Layout>